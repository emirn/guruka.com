---
import { getConfig, replacePlaceholders } from '../lib/config';
import SEO from '../components/SEO.astro';
import PreviewBanner from '../components/PreviewBanner.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Search from '../components/Search.astro';
import '../styles/global.css';
import '../styles/project.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  keywords?: string;
  ogTitle?: string;
  ogDescription?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  lang?: string;
  hreflangs?: Array<{ lang: string; href: string }>;
}

const config = getConfig();
const {
  title,
  description = config.branding.site.description,
  canonical,
  image,
  imageAlt,
  type = 'website',
  publishedTime,
  modifiedTime,
  author,
  keywords,
  ogTitle,
  ogDescription,
  twitterTitle,
  twitterDescription,
  lang,
  hreflangs,
} = Astro.props;

// For homepage (no title), use "Site Name | Tagline"
// For other pages, use "Page Title | Site Name"
const pageTitle = title
  ? `${title}${config.seo.title_separator || ' | '}${config.branding.site.name}`
  : config.branding.site.tagline
    ? `${config.branding.site.name}${config.seo.title_separator || ' | '}${config.branding.site.tagline}`
    : config.branding.site.name;

// Generate CSS variables from config colors
const cssVars = {
  '--color-primary': config.branding.colors.primary,
  '--color-primary-hover': config.branding.colors.secondary,
  '--color-text-primary': config.branding.colors.text_primary,
  '--color-text-secondary': config.branding.colors.text_secondary,
  '--color-text-muted': config.branding.colors.text_muted || '#9CA3AF',
  '--color-bg-primary': config.branding.colors.background,
  '--color-bg-secondary': config.branding.colors.background_secondary,
  '--color-border': config.branding.colors.border,
  '--color-dark-text-primary': config.branding.dark_mode.colors.text_primary,
  '--color-dark-text-secondary': config.branding.dark_mode.colors.text_secondary,
  '--color-dark-text-muted': config.branding.dark_mode.colors.text_muted || '#9CA3AF',
  '--color-dark-bg-primary': config.branding.dark_mode.colors.background,
  '--color-dark-bg-secondary': config.branding.dark_mode.colors.background_secondary,
  '--color-dark-border': config.branding.dark_mode.colors.border,
  '--color-dark-primary': config.branding.dark_mode.colors.primary || config.branding.colors.primary,
  '--font-family': config.typography.font_family || 'Inter, system-ui, sans-serif',
  '--font-heading': config.typography.heading_font_family || 'Inter, system-ui, sans-serif',
  '--logo-border-color': config.branding.colors.primary,
};
---

<!DOCTYPE html>
<html lang={lang || config.branding.site.language || 'en'}>
  <head>
    <SEO
      title={pageTitle}
      description={description}
      canonical={canonical}
      image={image}
      imageAlt={imageAlt}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
      keywords={keywords}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      twitterTitle={twitterTitle}
      twitterDescription={twitterDescription}
      config={config}
      hreflangs={hreflangs}
    />

    <!-- Google Fonts -->
    {config.typography.google_fonts && config.typography.google_fonts.length > 0 && (
      config.typography.local_fonts ? (
        <link rel="stylesheet" href="/fonts/google-fonts.css" />
      ) : (
        <>
          <link rel="preconnect" href="https://fonts.googleapis.com" />
          <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
          <link
            href={`https://fonts.googleapis.com/css2?family=${config.typography.google_fonts.join('&family=')}&display=swap`}
            rel="stylesheet"
          />
        </>
      )
    )}

    <!-- Custom Head Code -->
    {config.tracking.custom_head_code && <Fragment set:html={config.tracking.custom_head_code} />}

    <!-- Theme Initialization Script (in head to prevent flash) -->
    <script is:inline define:vars={{ darkModeDefault: config.branding.dark_mode.default, darkModeEnabled: config.branding.dark_mode.enabled }}>
      (function() {
        if (!darkModeEnabled) return;

        const savedTheme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)');
        const defaultTheme = darkModeDefault || 'light';

        let theme;
        if (savedTheme) {
          theme = savedTheme;
        } else if (prefersDark.media !== 'not all') {
          theme = prefersDark.matches ? 'dark' : 'light';
        } else {
          theme = defaultTheme;
        }

        document.documentElement.setAttribute('data-theme', theme);

        prefersDark.addEventListener('change', function(e) {
          if (!localStorage.getItem('theme')) {
            document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
          }
        });
      })();
    </script>

    <slot name="head" />
  </head>
  <body style={Object.entries(cssVars).map(([k, v]) => `${k}:${v}`).join(';')}>
    <div class="sticky top-0 z-50">
      <PreviewBanner config={config} />
      <Navigation config={config} />
    </div>

    <main>
      <slot />
    </main>

    <Footer config={config} />

    <!-- Search Modal -->
    {config.search?.enabled && <Search config={config} />}

    <!-- JSON-LD Structured Data -->
    {config.seo.enable_json_ld && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": config.branding.site.name,
        "url": config.branding.site.url,
        "description": config.branding.site.description,
        "publisher": {
          "@type": "Organization",
          "name": config.branding.site.name,
        }
      })} />
    )}

    <!-- Tracking Widget Code -->
    {config.tracking.widget_code && <Fragment set:html={config.tracking.widget_code} />}

    <!-- Custom Body Code -->
    {config.tracking.custom_body_code && <Fragment set:html={config.tracking.custom_body_code} />}

    <!-- Browser Language Auto-Detection -->
    {config.i18n?.enabled && (
      <script is:inline define:vars={{
        i18nLangs: config.i18n.languages?.map(l => l.code) || [],
        i18nDefault: config.i18n.defaultLanguage || 'en'
      }}>
      (function() {
        var key = location.hostname + '_lang';
        if (!localStorage.getItem(key)) {
          var browserLang = (navigator.language || '').split('-')[0].toLowerCase();
          if (browserLang && browserLang !== i18nDefault && i18nLangs.indexOf(browserLang) !== -1) {
            var segments = location.pathname.split('/').filter(Boolean);
            if (i18nLangs.indexOf(segments[0]) === -1) {
              localStorage.setItem(key, browserLang);
              location.href = '/' + browserLang + location.pathname;
              return;
            }
          }
        }
        // Rewrite internal links in main content for current language
        var contentSegments = location.pathname.split('/').filter(Boolean);
        var contentLang = i18nLangs.indexOf(contentSegments[0]) !== -1 ? contentSegments[0] : i18nDefault;
        if (contentLang !== i18nDefault) {
          var contentPrefix = '/' + contentLang;
          document.querySelectorAll('main a[href^="/"]').forEach(function(a) {
            var href = a.getAttribute('href');
            if (href === '#' || href.startsWith('#')) return;
            var fs = href.split('/').filter(Boolean)[0];
            if (i18nLangs.indexOf(fs) !== -1) return;
            a.setAttribute('href', contentPrefix + href);
          });
        }
      })();
      </script>
    )}

    <!-- Code block copy button + click-to-select -->
    <script is:inline>
    (function() {
      var copyIcon = '<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1z"/><path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0z"/></svg>';
      var checkIcon = '<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0"/></svg>';

      function addCopyButton(container, codeEl) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'code-copy-btn';
        btn.title = 'Copy';
        btn.setAttribute('aria-label', 'Copy code');
        btn.innerHTML = copyIcon;

        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          var text = codeEl.textContent || '';
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(function() { showCopied(btn); });
          } else {
            var ta = document.createElement('textarea');
            ta.value = text;
            ta.style.position = 'fixed';
            ta.style.left = '-9999px';
            document.body.appendChild(ta);
            ta.select();
            try { document.execCommand('copy'); showCopied(btn); } catch(err) {}
            document.body.removeChild(ta);
          }
        });

        container.appendChild(btn);

        codeEl.addEventListener('click', function() {
          var sel = window.getSelection();
          if (!sel || sel.isCollapsed || !codeEl.contains(sel.anchorNode)) {
            var range = document.createRange();
            range.selectNodeContents(codeEl);
            sel.removeAllRanges();
            sel.addRange(range);
          }
        });
      }

      // pre > code blocks (standard markdown code fences)
      document.querySelectorAll('pre').forEach(function(pre) {
        var code = pre.querySelector('code');
        if (!code) return;
        addCopyButton(pre, code);
      });

      // Standalone <code> blocks (not inside <pre>, must be block-level or multi-line)
      document.querySelectorAll('code').forEach(function(code) {
        if (code.closest('pre')) return; // already handled
        var display = getComputedStyle(code).display;
        var isBlock = display === 'block' || display === 'inline-flex' || display === 'flex';
        if (!isBlock && code.textContent.length < 40) return; // skip short inline code
        code.style.position = 'relative';
        addCopyButton(code, code);
      });

      function showCopied(btn) {
        btn.innerHTML = checkIcon;
        btn.classList.add('copied');
        btn.title = 'Copied!';
        setTimeout(function() {
          btn.innerHTML = copyIcon;
          btn.classList.remove('copied');
          btn.title = 'Copy';
        }, 1500);
      }
    })();
    </script>

  </body>
</html>
