---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getConfig } from '../lib/config';
import { getHomeArticles } from '../lib/sections';
import { getArticleLang } from '../lib/articles';
import Hero from '../components/Hero.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Pagination from '../components/Pagination.astro';
import PdfLightbox from '../components/PdfLightbox.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const config = getConfig();

// Read project-specific scripts (populated during build from config/styles/)
let projectScripts = '';
try {
  const raw = readFileSync(resolve(process.cwd(), 'src/scripts/project-scripts.js'), 'utf-8');
  if (raw.replace(/\/\*[\s\S]*?\*\//g, '').trim().length > 0) {
    projectScripts = raw;
  }
} catch { /* no project scripts */ }

// Check for custom root page
let customRoot: Awaited<ReturnType<typeof getCollection<'pages'>>>[number] | undefined;
try {
  const pages = await getCollection('pages');
  customRoot = pages.find((p) => p.slug === 'root');
} catch {
  // No pages collection — use default layout
}

let CustomContent: any;
if (customRoot) {
  const rendered = await customRoot.render();
  CustomContent = rendered.Content;
}

// Get home-page articles (filtered by sections config, or all if no sections)
const allHomeArticles = (await getHomeArticles(config))
  .sort((a, b) => b.data.published_at.valueOf() - a.data.published_at.valueOf());

// When i18n enabled, only show default-language articles on homepage
const defaultLang = config.i18n?.defaultLanguage || 'en';
const articles = config.i18n?.enabled
  ? allHomeArticles.filter(a => getArticleLang(a.slug, config) === defaultLang)
  : allHomeArticles;

// Pagination
const postsPerPage = customRoot?.data.blog_grid_limit || config.blog.posts_per_page || 9;
const totalPages = Math.ceil(articles.length / postsPerPage);
const paginatedArticles = articles.slice(0, postsPerPage);

// Should we show the blog grid?
const showBlogGrid = customRoot ? customRoot.data.blog_grid : true;
const blogGridTitle = customRoot?.data.blog_grid_title || config.blog.section_title;
---

<BaseLayout title={customRoot?.data.title} description={customRoot?.data.description} image={customRoot ? (customRoot.data.image_og || `/assets/pages/${customRoot.slug}/og.webp`) : undefined}>
  {projectScripts && <script is:inline set:html={projectScripts} />}
  {customRoot ? (
    <>
      {customRoot.data.image_hero && !customRoot.data.full_width && (
        <section class="relative">
          <img
            src={customRoot.data.image_hero}
            alt={customRoot.data.title}
            class="w-full h-64 sm:h-80 lg:h-96 object-cover"
          />
        </section>
      )}
      {customRoot.data.full_width ? (
        <div>
          <CustomContent />
        </div>
      ) : (
        <article class="prose dark:prose-invert max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
          <CustomContent />
        </article>
      )}
    </>
  ) : (
    <Hero config={config} />
  )}

  {showBlogGrid && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      {blogGridTitle && (
        <h2 class="text-sm font-semibold text-[var(--color-primary)] uppercase tracking-wider mb-8">
          {blogGridTitle}
        </h2>
      )}

      {paginatedArticles.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {paginatedArticles.map((article) => (
            <ArticleCard article={article} config={config} />
          ))}
        </div>
      ) : (
        <p class="text-center text-[var(--color-text-secondary)] dark:text-[var(--color-dark-text-secondary)] py-12">
          No articles published yet.
        </p>
      )}

      <Pagination currentPage={1} totalPages={totalPages} />
    </section>
  )}
  <PdfLightbox />
</BaseLayout>
