---
import type { GetStaticPaths } from 'astro';
import ArticleLayout from '../layouts/ArticleLayout.astro';
import GuideLayout from '../layouts/GuideLayout.astro';
import { getConfig } from '../lib/config';
import { getPublishedArticles, getArticleLang, getArticleBaseSlug } from '../lib/articles';
import { getSectionFromSlug, getSections } from '../lib/sections';

const config = getConfig();

// Built-in layout map
const builtinLayouts: Record<string, any> = {
  article: ArticleLayout,
  guide: GuideLayout,
};

// Discover custom layouts (only resolved when custom_layouts.enabled)
const customLayoutModules = config.custom_layouts?.enabled
  ? import.meta.glob('../layouts/custom/*.astro')
  : {};

async function resolveLayout(templateName: string | undefined) {
  const name = templateName || 'article';

  // Check built-in layouts first
  if (builtinLayouts[name]) return builtinLayouts[name];

  // Check custom layouts
  if (config.custom_layouts?.enabled) {
    const customPath = `../layouts/custom/${name}.astro`;
    if (customLayoutModules[customPath]) {
      const mod = await customLayoutModules[customPath]();
      return (mod as any).default;
    }
  }

  // Fallback to article layout
  return ArticleLayout;
}

export const getStaticPaths = (async () => {
  const config = getConfig();
  const articles = await getPublishedArticles();

  if (!config.i18n?.enabled) {
    return articles.map((article) => ({
      params: { slug: article.slug },
      props: { article },
    }));
  }

  const defaultLang = config.i18n.defaultLanguage || 'en';
  const nonDefaultLangs = (config.i18n.languages?.map(l => l.code) || []).filter(c => c !== defaultLang);

  const paths = articles.map((article) => {
    const lang = getArticleLang(article.slug, config);
    const baseSlug = getArticleBaseSlug(article.slug, config);
    // Default lang: /blog/article/ — Other langs: /es/blog/article/
    const urlSlug = lang === defaultLang ? baseSlug : `${lang}/${baseSlug}`;
    return {
      params: { slug: urlSlug },
      props: { article, lang },
    };
  });

  // Build a map of baseSlug → set of languages that have translations
  const translationMap = new Map<string, Set<string>>();
  for (const article of articles) {
    const baseSlug = getArticleBaseSlug(article.slug, config);
    const lang = getArticleLang(article.slug, config);
    if (!translationMap.has(baseSlug)) translationMap.set(baseSlug, new Set());
    translationMap.get(baseSlug)!.add(lang);
  }

  // For each default-lang article, generate fallback routes for non-default
  // languages that don't have a translation yet
  const defaultLangArticles = articles.filter(a => getArticleLang(a.slug, config) === defaultLang);
  for (const article of defaultLangArticles) {
    const baseSlug = getArticleBaseSlug(article.slug, config);
    const existingLangs = translationMap.get(baseSlug) || new Set();
    for (const lang of nonDefaultLangs) {
      if (!existingLangs.has(lang)) {
        paths.push({
          params: { slug: `${lang}/${baseSlug}` },
          props: { article, lang: defaultLang },
        });
      }
    }
  }

  return paths;
}) satisfies GetStaticPaths;

const { article, lang } = Astro.props;
const { Content, headings } = await article.render();

// Determine section and template
const sectionId = getSectionFromSlug(article.slug, config);
const sections = getSections(config);
const sectionConfig = sectionId ? sections.find(s => s.id === sectionId) : null;
const Layout = await resolveLayout(sectionConfig?.template);

// Find related articles (only for article layout, same language)
const allArticles = await getPublishedArticles();
const isArticleLayout = !sectionConfig?.template || sectionConfig.template === 'article';
let relatedArticles: typeof allArticles = [];

if (isArticleLayout) {
  const articleLang = lang || getArticleLang(article.slug, config);
  relatedArticles = allArticles
    .filter((a) => a.slug !== article.slug)
    .filter((a) => {
      // Only relate articles in the same language
      if (config.i18n?.enabled && getArticleLang(a.slug, config) !== articleLang) return false;

      const currentKeywords = article.data.keywords || [];
      const currentCategories = article.data.categories || [];
      const currentTags = article.data.tags || [];

      const otherKeywords = a.data.keywords || [];
      const otherCategories = a.data.categories || [];
      const otherTags = a.data.tags || [];

      const sharedKeywords = currentKeywords.some((k) => otherKeywords.includes(k));
      const sharedCategories = currentCategories.some((c) => otherCategories.includes(c));
      const sharedTags = currentTags.some((t) => otherTags.includes(t));

      return sharedKeywords || sharedCategories || sharedTags;
    })
    .sort((a, b) => b.data.published_at.valueOf() - a.data.published_at.valueOf())
    .slice(0, 3);
}

// Build hreflang array for SEO
let hreflangs: Array<{ lang: string; href: string }> = [];
if (config.i18n?.enabled) {
  const baseUrl = (config.seo.canonical_domain || config.branding.site.url).replace(/\/$/, '');
  const currentBaseSlug = getArticleBaseSlug(article.slug, config);
  const defaultLang = config.i18n.defaultLanguage || 'en';

  for (const a of allArticles) {
    if (getArticleBaseSlug(a.slug, config) === currentBaseSlug && a.slug !== article.slug) {
      const otherLang = getArticleLang(a.slug, config);
      const otherUrl = otherLang === defaultLang
        ? `${baseUrl}/${currentBaseSlug}/`
        : `${baseUrl}/${otherLang}/${currentBaseSlug}/`;
      hreflangs.push({ lang: otherLang, href: otherUrl });
    }
  }
  // Add self
  const selfLang = getArticleLang(article.slug, config);
  const selfUrl = selfLang === defaultLang
    ? `${baseUrl}/${currentBaseSlug}/`
    : `${baseUrl}/${selfLang}/${currentBaseSlug}/`;
  hreflangs.push({ lang: selfLang, href: selfUrl });
}
---

<Layout article={article} headings={headings} relatedArticles={relatedArticles} sectionConfig={sectionConfig} lang={lang} hreflangs={hreflangs}>
  <Content />
</Layout>
