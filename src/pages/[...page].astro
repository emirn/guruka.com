---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getConfig } from '../lib/config';
import { getHomeArticles } from '../lib/sections';
import { getPageLang, getPageBaseSlug } from '../lib/articles';
import PdfLightbox from '../components/PdfLightbox.astro';
import ImageLightbox from '../components/ImageLightbox.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

// Read project-specific scripts (populated during build from config/styles/)
let projectScripts = '';
try {
  const raw = readFileSync(resolve(process.cwd(), 'src/scripts/project-scripts.js'), 'utf-8');
  // Skip if file is just the placeholder comment
  if (raw.replace(/\/\*[\s\S]*?\*\//g, '').trim().length > 0) {
    projectScripts = raw;
  }
} catch { /* no project scripts */ }

export async function getStaticPaths() {
  const config = getConfig();
  let pages: Awaited<ReturnType<typeof getCollection<'pages'>>>;
  try {
    pages = await getCollection('pages');
  } catch {
    return [];
  }

  if (!config.i18n?.enabled) {
    return pages
      .filter((p) => p.slug !== 'root')
      .map((page) => ({
        params: { page: page.slug },
        props: { page },
      }));
  }

  const defaultLang = config.i18n.defaultLanguage || 'en';
  const langs = config.i18n.languages?.map(l => l.code) || [defaultLang];

  return pages
    .filter(p => {
      // Filter out bare 'root' (handled by index.astro)
      if (p.slug === 'root') return false;
      // Filter out bare lang codes (e.g., slug === 'es') — these are NOT valid
      // {lang}/root pages are valid and get routed to /{lang}/
      return true;
    })
    .map(page => {
      const lang = getPageLang(page.slug, config);
      const baseSlug = getPageBaseSlug(page.slug, config);

      // {lang}/root → route to /{lang}/ (language homepage)
      if (baseSlug === 'root') {
        return {
          params: { page: lang },
          props: { page, lang },
        };
      }

      const urlSlug = lang === defaultLang ? baseSlug : `${lang}/${baseSlug}`;
      return {
        params: { page: urlSlug },
        props: { page, lang },
      };
    });
}

const { page, lang } = Astro.props;
const { Content } = await page.render();
const config = getConfig();

// OG image: explicit frontmatter value or auto-generated fallback
const ogImage = page.data.image_og || `/assets/pages/${page.slug}/og.webp`;

// Load articles for blog grid if enabled
let gridArticles: Awaited<ReturnType<typeof getHomeArticles>> = [];
if (page.data.blog_grid) {
  gridArticles = (await getHomeArticles(config))
    .sort((a, b) => b.data.published_at.valueOf() - a.data.published_at.valueOf())
    .slice(0, page.data.blog_grid_limit || 9);
}
---

<BaseLayout title={page.data.title} description={page.data.description} image={ogImage} lang={lang}>
  {projectScripts && <script is:inline set:html={projectScripts} />}
  {page.data.image_hero && !page.data.full_width && (
    <section class="relative">
      <img
        src={page.data.image_hero}
        alt={page.data.title}
        class="w-full h-64 sm:h-80 lg:h-96 object-cover"
      />
    </section>
  )}

  {page.data.full_width ? (
    <div>
      <Content />
    </div>
  ) : (
    <article class="prose dark:prose-invert max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <Content />
    </article>
  )}

  {page.data.blog_grid && gridArticles.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      {page.data.blog_grid_title && (
        <h2 class="text-sm font-semibold text-[var(--color-primary)] uppercase tracking-wider mb-8">
          {page.data.blog_grid_title}
        </h2>
      )}

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {gridArticles.map((article) => (
          <ArticleCard article={article} config={config} />
        ))}
      </div>
    </section>
  )}
  <PdfLightbox />
  <ImageLightbox />
</BaseLayout>
